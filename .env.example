# Stock Dashboard Environment Configuration
# Copy to .env and fill in your values

# ── General ──────────────────────────────────────────
SD_ENV=dev
SD_DEBUG=false
SD_LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────
# Dev: SQLite (no setup needed)
SD_DATABASE_URL=sqlite:///./stock_dashboard.db
# Prod: PostgreSQL
# SD_DATABASE_URL=postgresql://user:pass@localhost:5432/stock_dashboard

# ── Redis ────────────────────────────────────────────
SD_REDIS_URL=redis://localhost:6379/0

# ── API Keys ─────────────────────────────────────────
# FMP: Get free key at https://site.financialmodelingprep.com/developer/docs
SD_FMP_API_KEY=

# Alpaca: Get free key at https://alpaca.markets (for real-time + future trading)
SD_ALPACA_API_KEY=
SD_ALPACA_SECRET_KEY=
SD_ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional providers
# SD_POLYGON_API_KEY=
# SD_FINNHUB_API_KEY=
# SD_TIINGO_API_KEY=

# ── Provider Selection ───────────────────────────────
# Options: fmp, yfinance (dev only), alpaca (when implemented)
SD_PROVIDER_FUNDAMENTALS=fmp
SD_PROVIDER_EOD_PRICES=fmp
SD_PROVIDER_HISTORICAL=fmp
SD_PROVIDER_INTRADAY=fmp
SD_PROVIDER_UNIVERSE=fmp

# ── Pipeline Scheduling (cron format) ────────────────
SD_UNIVERSE_REFRESH_CRON=0 5 * * 1
SD_EOD_REFRESH_CRON=0 18 * * 1-5
SD_SCREENER_RUN_CRON=30 18 * * 1-5

# ── Screening Defaults ───────────────────────────────
SD_MIN_MARKET_CAP=100000000
SD_MIN_AVG_VOLUME=200000
SD_MIN_PRICE=5.0
